{
  "name": "@membase/openclaw-membase",
  "version": "0.3.1",
  "main": "./index.ts",
  "description": "Membase plugin for OpenClaw — persistent long-term memory for AI agents",
  "type": "module",
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "prepublishOnly": "bun run build",
    "format": "biome format --write .",
    "lint": "biome check .",
    "check-types": "tsc --noEmit"
  },
  "files": [
    "dist/",
    "src/",
    "index.ts",
    "openclaw.plugin.json"
  ],
  "keywords": [
    "openclaw",
    "membase",
    "memory",
    "ai",
    "plugin",
    "long-term-memory",
    "knowledge-graph",
    "vector-search",
    "ai-agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aristoapp/openclaw-membase.git"
  },
  "homepage": "https://github.com/aristoapp/openclaw-membase#readme",
  "bugs": {
    "url": "https://github.com/aristoapp/openclaw-membase/issues"
  },
  "peerDependencies": {
    "openclaw": ">=2026.1.0"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@types/bun": "^1.2.14",
    "typescript": "5.9.2"
  }
}
